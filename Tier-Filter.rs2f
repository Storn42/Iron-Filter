/*@ define:input:food_and_pots
label: Supply Drops
type: style
group: Styles
exampleItem: Wild pie
*/

#define SUPPLY_DROP_STYLE \
    fontType = 2; \
	hidden = false;
	
#define SUPPLY_DROP_RULESET(_area, _name) \
rule (area:_area && name:_name && (!ownership:2 || SHOW_OTHER_DROPS)) {SUPPLY_DROP_STYLE}

