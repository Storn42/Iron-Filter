#define UNQIQUE_SPECIAL_C_NAMES []

#define SPECIAL_UNIQUE_CHECK(_enabled, _area, _name) \
	rule (_enabled && _area && name:_name && name:UNQIQUE_SPECIAL_SS_NAMES) {UNIQUE_SS_STYLE} \
	rule (_enabled && _area && name:_name && name:UNQIQUE_SPECIAL_S_NAMES) {UNIQUE_S_STYLE} \
	rule (_enabled && _area && name:_name && name:UNQIQUE_SPECIAL_A_NAMES) {UNIQUE_A_STYLE} \
	rule (_enabled && _area && name:_name && name:UNQIQUE_SPECIAL_B_NAMES) {UNIQUE_B_STYLE} \
	rule (_enabled && _area && name:_name && name:UNQIQUE_SPECIAL_C_NAMES) {UNIQUE_C_STYLE}

/*@ define:module:slayer_pvm
name: Monsters
subtitle: Hide Drops, Highlight Supplies, and Enable Meme Drops
description: Here you will be able to set custom hide and highlight supply drops from different monsters you find across the game. 
*/

/*@ define:input:slayer_pvm
label: Abyssal Dagger Meme Drop
type: boolean
group: Abyssal Demons
*/

#define ENABLE_ABBY_DAGGER_MEME true

// [1666,10083,0,1682,10103,0] - Catacombs of Kourend - Main
// [1667,10050,0,1684,10064,0] - Catacombs of Kourend - Center
// [3405,3555,2,3580,10064,2] - Slayer Tower
// [3423,9953,3,3448,9953,3] - Slayer Tower - Basement
// [3331,10152,0,3352,10174,0] - Wilderness Slayer Cave
// [3011,4867,0,3069,4926,0] - Abyssal Area

#define ABBY_DEMON_AREA (area:[1666,10083,0,1682,10103,0] || area:[1667,10050,0,1684,10064,0] || area:[3405,3555,2,3580,10064,2] || area:[3423,9953,3,3448,9953,3] || area:[1666,10083,0,1682,10103,0] || area:[3331,10152,0,3352,10174,0]) 

SPECIAL_UNIQUE_CHECK(ENABLE_ABBY_DAGGER_MEME, ABBY_DEMON_AREA, "Abyssal dagger")

/*@ define:input:slayer_pvm
label: Ignore Me
type: stringlist
group: Abyssal Demons
*/

#define ABBYDEMONS_IGNORE []

/*@ define:input:slayer_pvm
label: Ignore Me
type: stringlist
group: Abyssal Demons
*/

#define ABBYDEMONS_IGNORE2 []

/*@ define:input:slayer_pvm
label: Catacombs of Kourend - Hide Items
type: stringlist
group: Abyssal Demons
*/

#define ABBYDEMONS_CATACOMBS_HIDE []

rule (area:[1666,10083,0,1682,10103,0] && name:ABBYDEMONS_CATACOMBS_HIDE) {hidden = true;} // Catacombs of Kourend - Main
rule (area:[1667,10050,0,1684,10064,0] && name:ABBYDEMONS_CATACOMBS_HIDE) {hidden = true;} // Catacombs of Kourend - Center

/*@ define:input:slayer_pvm
label: Catacombs of Kourend - Show Items
type: stringlist
group: Abyssal Demons
*/

#define ABBYDEMONS_CATACOMBS_SHOW []

FORCE_SHOW_RULESET([1666,10083,0,1682,10103,0], ABBYDEMONS_CATACOMBS_SHOW) // Catacombs of Kourend - Main
FORCE_SHOW_RULESET([1667,10050,0,1684,10064,0], ABBYDEMONS_CATACOMBS_SHOW) // Catacombs of Kourend - Center

/*@ define:input:slayer_pvm
label: Catacombs of Kourend - Supply Drop
type: enumlist
enum: ["Lobster"]
group: Abyssal Demons
*/

#define ABBYDEMONS_CATACOMBS_SUPPLY []

SUPPLY_DROP_RULESET([1666,10083,0,1682,10103,0], ABBYDEMONS_CATACOMBS_SUPPLY) // Catacombs of Kourend - Main
SUPPLY_DROP_RULESET([1667,10050,0,1684,10064,0], ABBYDEMONS_CATACOMBS_SUPPLY) // Catacombs of Kourend - Center

/*@ define:input:slayer_pvm
label: Slayer Tower - Hide Items
type: stringlist
group: Abyssal Demons
*/

#define ABBYDEMONS_SLAYER_TOWER_HIDE []

rule (area:[3405,3555,2,3580,10064,2] && name:ABBYDEMONS_SLAYER_TOWER_HIDE) {hidden = true;} // Slayer Tower
rule (area:[3423,9953,3,3448,9953,3] && name:ABBYDEMONS_SLAYER_TOWER_HIDE) {hidden = true;} // Slayer Tower - Basement

/*@ define:input:slayer_pvm
label: Slayer Tower - Show Items
type: stringlist
group: Abyssal Demons
