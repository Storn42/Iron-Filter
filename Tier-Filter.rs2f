/*@ define:module:header
hidden: true
name: header
*/

meta {
    name = "Storn's Tier Filter";
    description = "A Proof of Concept for Tier Based Filtering";
	}

/*@ define:module:greetings
name: This Is a Test
description:
    This is WIP for a filter that sorts by item tiers rather than ge value. It is not finished. It is not usable. 


  Things to Finish

  - Bosses

  - Minigames

  - Clues
*/

/*@ define:module:settings
name: Settings
subtitle: Basic Global Settings 
*/

/*@ define:input:settings
label: World Spawns
type: boolean
group: Show
*/
#define SHOW_GLOBAL_DROPS true

apply (!SHOW_GLOBAL_DROPS && ownership:0) {hidden = true;}

/*@ define:input:settings
label: Unowned Drops
type: boolean
group: Show
*/
#define SHOW_OTHER_DROPS false

apply (!SHOW_OTHER_DROPS && ownership:2) {hidden = true;}

#define FORCE_SHOW_RULESET(_area, _name) \
rule (area:_area && name:_name && (!ownership:2 || SHOW_OTHER_DROPS)) {hidden = false;}

/*@ define:input:settings
label: Despawn Timer
type: boolean
group: Show
*/

#define SHOW_DEPSAWN_TIMER true

apply (SHOW_DEPSAWN_TIMER) {showDespawn = true;}

/*@ define:input:settings
label: Item Value
type: boolean
group: Show
*/

#define SHOW_ITEM_VALUE false

apply (SHOW_ITEM_VALUE) {showValue = true;}

/*@ define:input:settings
label: Item Icon
type: boolean
group: Show
*/

#define SHOW_ITEM_ICON false

apply (SHOW_ITEM_ICON) {icon = CurrentItem();}


/*@ define:module:hidden
name: Hidden Items
subtitle: For when you NEVER want to see that item again  
*/

/*@ define:input:hidden
label: User Hide
type: stringlist
group: User
*/

#define HIDE_USER []

apply (name:HIDE_USER) {hidden=true;}

/*@ define:input:hidden
label: Hide if Unnoted
type: stringlist
group: User
*/

#define HIDE_USER_UNNOTED []

apply (name:HIDE_USER_UNNOTED && stackable:false)  {hidden=true;}

/*@ define:input:hidden
label: Hide if quant < 10
type: stringlist
group: User
*/

#define HIDE_USER_UNDER_10 []

apply (name:HIDE_USER_UNDER_10 && quantity:<10) {hidden=true}

/*@ define:input:hidden
label: Hide if quant < 100
type: stringlist
group: User
*/

#define HIDE_USER_UNDER_100 []

apply (name:HIDE_USER_UNDER_100 && quantity:<100) {hidden=true}

/*@ define:input:hidden
label: Hide if quant < 1000
