	menuTextColor = "#FFFFBFEA"; \
	textAccent = 3; \
	fontType = 3; \
	showLootbeam = true;

/*@ define:input:fallback
label: A Tier
type: style
*/

#define FALLBACK_A_STYLE \
	textColor = "#ffffffff"; \
	backgroundColor = "#ccffcc00"; \
	borderColor = "#ffffffff"; \
	menuTextColor = "#ffffcc00"; \
	textAccent = 3; \
	fontType = 2;

/*@ define:input:fallback
label: B Tier
type: style
*/

#define FALLBACK_B_STYLE \
	textColor = "#ffffffff"; \
	backgroundColor = "#7000c8ff"; \
	menuTextColor = "#ff00c9ff"; \
	textAccent = 3;

/*@ define:input:fallback
label: C Tier
type: style
*/

#define FALLBACK_C_STYLE \
	textColor = "#ffffffff"; \
	backgroundColor = "#337bff1f"; \
	menuTextColor = "#ff7bff1f"; \
	textAccent = 3;
	
/*@ define:input:fallback
label: D Tier
type: style
*/

#define FALLBACK_D_STYLE \
	textColor = "#ffffffff";

rule (value:>=FALLBACK_VALUE_SS) {FALLBACK_SS_STYLE}
rule (value:>=FALLBACK_VALUE_S) {FALLBACK_S_STYLE}
rule (value:>=FALLBACK_VALUE_A) {FALLBACK_A_STYLE}
rule (value:>=FALLBACK_VALUE_B) {FALLBACK_B_STYLE}
rule (value:>=FALLBACK_VALUE_C) {FALLBACK_C_STYLE}
rule (value:>=FALLBACK_VALUE_D) {FALLBACK_D_STYLE}