/*@ define:input:boss_pvm
label: Sound ID
type: number
group: The Leviathan
*/

#define LEVIATHAN_PERFECT_SOUND 3018

#define LEVIATHAN_PERFECT_ITEMS ((name:"Coal" && quantity:==292) || (name:"Gold ore" && quantity:==101) || (name:"Dragon javelin head" && quantity:==81) || (name:"Anglerfish" && quantity:==6) || (name:"Uncut ruby" && quantity:==56) || (name: "Uncut diamond" && quantity:==56) || (name:"Runite ore" && quantity:== 40) || (name:"Dragon bolts (unf)" && quantity:== 225) || (name:"Pure essence" && quantity:== 270) || (name:"Iron ore" && quantity:== 85) || (name:"Silver ore" && quantity:==85) || (name:"Adamantite ore" && quantity:==85) || (name:"Sapphire" && quantity:==38) || (name:"Emerald" && quantity:==38) || (name:"Ruby" && quantity:==38) || (name:"Onyx bolt tips" && quantity:==135) || (name:"Raw manta ray" && quantity:==270) || (name:"Rune arrow" && quantity:==81) || (name:"Smoke rune" && quantity:==450) || (name:"Soul rune" && quantity:==900) || (name:"Bronze arrow" && quantity:==94) || (name:"Mithril arrow" && quantity:==94) || (name:"Adamant arrow" && quantity:==94) || (name:"Body rune" && quantity:==270) || (name:"Earth rune" && quantity:==270))

AREA_UNHIDE(area:[2068,6360,0,2096,6386,3] && ENABLE_LEVIATHAN_PERFECT && LEVIATHAN_PERFECT_ITEMS)

apply (area:[2068,6360,0,2096,6386,3] && ENABLE_LEVIATHAN_PERFECT && LEVIATHAN_PERFECT_ITEMS) {sound=LEVIATHAN_PERFECT_SOUND;}

